[global]
monitor=0
follow=mouse
width=360
height=140
origin=top-right
offset=18x18
scale=0
notification_limit=8
progress_bar=true
progress_bar_height=8
progress_bar_frame_width=1
progress_bar_min_width=150
progress_bar_max_width=300
progress_bar_corner_radius=8
indicate_hidden=yes
transparency=10
separator_height=0
padding=16
horizontal_padding=16
text_icon_padding=12
frame_width=2
frame_color="#53f2f2"
separator_color=frame
corner_radius=16
font=Terminess Nerd Font 12
line_height=2
markup=full
format="<b>%s</b>\n%b"
alignment=left
vertical_alignment=center
show_age_threshold=60
ellipsize=middle
word_wrap=yes
ignore_newline=no
stack_duplicates=true
hide_duplicate_count=false
show_indicators=yes
icon_position=left
min_icon_size=48
max_icon_size=64
icon_corner_radius=10
sticky_history=yes
history_length=20
mouse_left_click=close_current
mouse_middle_click=do_action
mouse_right_click=close_all
browser=xdg-open

[urgency_low]
background="#0b1020dd"
foreground="#f5fbff"
highlight="#53f2f2"
timeout=4

[urgency_normal]
background="#131b35dd"
foreground="#f5fbff"
highlight="#53f2f2"
timeout=6

[urgency_critical]
background="#2d1033ee"
foreground="#ffffff"
highlight="#ff5fd7"
frame_color="#ff5fd7"
timeout=0
